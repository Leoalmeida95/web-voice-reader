{
  "manifest_version": 3,
  "name": "Web Voice Reader",
  "version": "1.0",
  "description": "Envie o texto da página para narração por backend local.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["readability.js", "content.js"]
    }
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  }
}
